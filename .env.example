# Copia este archivo a .env y edítalo.
# Ejemplo:
#   cp .env.example .env
#   nano .env

# IP pública de la VPS
PUBLIC_IP=PUT_YOUR_PUBLIC_IP_HERE

# Hostname temporal recomendado si no tienes dominio real.
# Si usas sslip.io, normalmente será: <IP>.sslip.io
PANEL_HOST=PUT_YOUR_PUBLIC_IP_HERE.sslip.io

# URL pública del panel
APP_URL=http://PUT_YOUR_PUBLIC_IP_HERE.sslip.io

# Zona horaria
APP_TIMEZONE=UTC

# Correo del panel (de momento solo informativo si no configuras SMTP real)
PANEL_EMAIL=admin@your-domain-or-hostname

# Base de datos
DB_NAME=panel
DB_USER=pterodactyl
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD
DB_PORT=3306

# Puertos
PANEL_HTTP_PORT=80
WINGS_API_PORT=8080
WINGS_SFTP_PORT=2022

# Usuario interno de Wings
WINGS_UID=988
WINGS_GID=988
WINGS_USERNAME=pterodactyl

# Red interna fija para evitar conflicto con la red pterodactyl0 de Wings
COMPOSE_SUBNET=172.19.0.0/24
PANEL_CONTAINER_IP=172.19.0.4
WINGS_CONTAINER_IP=172.19.0.5

# Recursos sugeridos del nodo
NODE_MEMORY_MB=3000
NODE_DISK_MB=70000
NODE_UPLOAD_MB=100
NODE_DAEMON_BASE=/var/lib/pterodactyl/volumes

# Datos del nodo en el panel
NODE_NAME=local-node
NODE_DESCRIPTION='Panel and Wings on same VPS'
NODE_LOCATION_SHORT=local
NODE_LOCATION_LONG='Local VPS'

# Admin inicial (lo usa create-admin.sh)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
